{
    "version": "1.15.0",
    "description": "Install and run Python applications in isolated environments",
    "homepage": "https://pipx.pypa.io/",
    "license": "MIT",
    "suggest": {
        "Python": "python"
    },
    "url": "https://github.com/pypa/pipx/releases/download/1.15.0/pipx.pyz",
    "hash": "6b6e1b016bf7df9debee590ca32204a85ff18a87514e6a3b4413d8ad7ff73ed3",
    "bin": "pipx.bat",
    "pre_install": "Set-Content -Value '@python \"%~dp0pipx.pyz\" %*' -Path \"$dir\\pipx.bat\"",
    "checkver": {
        "github": "https://github.com/pypa/pipx"
    },
    "persist": "pipx",
    "env_add_path": "pipx\\bin",
    "env_set": {
        "PIPX_HOME": "$dir\\pipx",
        "PIPX_BIN_DIR": "$dir\\pipx\\bin",
        "PIPX_MAN_DIR": "$dir\\pipx\\man",
        "PIPX_SHARED_LIBS": "$dir\\pipx\\shared",
        "PIPX_LOCAL_VENVS": "$dir\\pipx\\venvs",
        "PIPX_LOG_DIR": "$dir\\pipx\\logs",
        "PIPX_TRASH_DIR": "$dir\\pipx\\trash",
        "PIPX_VENV_CACHEDIR": "$dir\\pipx\\.cache",
        "PIPX_STANDALONE_PYTHON_CACHEDIR": "$dir\\pipx\\py"
    },
    "autoupdate": {
        "url": "https://github.com/pypa/pipx/releases/download/$version/pipx.pyz"
    }
}
